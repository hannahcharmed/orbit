# Anthropic API key — required for AI Coach and insights features
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Platform OAuth credentials — required to connect creator accounts
# Leave blank to run in demo mode (no platform connections)

# Instagram / Facebook (Meta for Developers)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# TikTok (TikTok for Developers)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Snapchat (Snap Kit)
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# Twitch (Twitch Developer Console)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Base URL — update when deploying
NEXTAUTH_URL=http://localhost:3000
